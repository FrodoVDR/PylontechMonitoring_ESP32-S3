// Registrierung ------------------------------------------------------

inline void registerPylontechAPI() {
    // BAT
    server.on("/api/pylontech/bat",  HTTP_GET,  handleBatGet);
    server.on("/api/pylontech/bat",  HTTP_POST, handleBatPost);

    // PWR
    server.on("/api/pylontech/pwr",  HTTP_GET,  handlePwrGet);
    server.on("/api/pylontech/pwr",  HTTP_POST, handlePwrPost);

    // STAT
    server.on("/api/pylontech/stat", HTTP_GET,  handleStatGet);
    server.on("/api/pylontech/stat", HTTP_POST, handleStatPost);
}
